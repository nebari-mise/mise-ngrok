#!/usr/bin/env bash
set -euo pipefail

version="$ASDF_INSTALL_VERSION"
install_path="$ASDF_INSTALL_PATH"

os="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"
case "$arch" in
  aarch64|arm64) arch="arm64" ;;
  x86_64)        arch="amd64" ;;
  *)             echo "Unsupported arch: $arch" >&2; exit 1 ;;
esac

# macOS uses opaque CDN tokens from Homebrew cask.
# Linux uses the public equinox.io download URL (no token needed).
if [[ "$os" == "darwin" ]]; then
  case "${version},${arch}" in
    3.37.3,arm64) hash="5mfSNpNhBZC" ;;
    3.37.3,amd64) hash="gcLZ7yYLAxt" ;;
    *) echo "No ngrok download hash for ${version} darwin-${arch}" >&2
       echo "Update bin/install with the hash from the Homebrew cask:" >&2
       echo "https://github.com/Homebrew/homebrew-cask/blob/main/Casks/n/ngrok.rb" >&2
       exit 1 ;;
  esac
  url="https://bin.ngrok.com/a/${hash}/ngrok-v3-${version}-${os}-${arch}.zip"
else
  url="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-${version}-${os}-${arch}.zip"
fi

mkdir -p "${install_path}/bin"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

echo "Downloading ngrok ${version} (${os}-${arch})..."
curl -fsSL "$url" -o "${tmp}/ngrok.zip"
unzip -q "${tmp}/ngrok.zip" -d "${install_path}/bin"
chmod +x "${install_path}/bin/ngrok"
